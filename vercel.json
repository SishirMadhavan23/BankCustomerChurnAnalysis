{
  "buildCommand": "pip install -r requirements-deploy.txt && python -m app.model",
  "installCommand": "pip install -r requirements-deploy.txt",
  "env": {
    "PYTHONUNBUFFERED": "1",
    "FLASK_ENV": "production"
