# Environment Configuration Example
# Copy this file to .env and fill in your actual values
# Do NOT commit .env to version control

# Application
APP_NAME=Bank Customer Churn Analysis
APP_VERSION=1.0.0
DEBUG=false

# Model Configuration
MODEL_PATH=model/churn_model.pkl
SCALER_PATH=model/scaler.pkl
LABEL_GEO_PATH=model/label_geo.pkl
LABEL_GENDER_PATH=model/label_gender.pkl

# Dataset
DATASET_PATH=data/Churn_Modelling.csv

# Flask (if using Flask backend)
FLASK_ENV=production
FLASK_DEBUG=false
SECRET_KEY=your-secret-key-here

# Streamlit
STREAMLIT_SERVER_PORT=8501
STREAMLIT_SERVER_HEADLESS=true

# API Keys (if needed for external services)
# OPENAI_API_KEY=your-openai-key
# ANTHROPIC_API_KEY=your-anthropic-key

# Database (if applicable)
# DATABASE_URL=postgresql://user:pass@localhost:5432/bcca

# Logging
LOG_LEVEL=INFO
LOG_FILE=logs/app.log

# Security
# CORS_ORIGINS=http://localhost:8501,http://localhost:3000